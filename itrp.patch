+    float hs_y;        // Amount to distort the yellow hue angle towards red as intensity decreases.
+    float hs_y_rng;    // Range of the yellow hueshift: higher values affect more of the upper intensity range.
+
+    // Surround
+    int tn_su; // OpenDRT includes a simple surround compensation model. DCI cinema presets use dark surround. Rec.1886 uses dim surround. And sRGB Display uses bright surround. This functionality should provide a better perceptual match between viewing environments.
