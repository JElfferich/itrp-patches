+    float tn_Lg;    // Display grey luminance in nits (controls mid-grey, usually 10.0).
+    float tn_gb;    // HDR grey boost — increases mid-grey as peak luminance rises (typical 0.13).
+    int tn_su;      // Surround: 0=Dark, 1=Dim, 2=Bright. Applies unconstrained surround compensation to ts_p.
+
+    // Contrast high
+    bool tn_hcon_enable; // Contrast High allows control of the upper section of the tonescale function.
+    float tn_hcon;       // Amount adjust highlights. Positive values increase highlight exposure, negative values decrease.
+    float tn_hcon_pv;    // Amount of stops above middle grey (0.18) to start the adjustment.
+    float tn_hcon_st;    // How quickly above the Contrast High Pivot the effect begins.
+
+    // Contrast low
+    bool tn_lcon_enable; // Contrast Low adds contrast to the midtones and shadows.
+    float tn_lcon;       // Amount of contrast to add. 0.0 has no effect. 1.0 will expose down by 1 stop at the origin.
+    float tn_lcon_w;     // The width of the adjustment.
+
+    // Creative white
+    int cwp;        // Creative whitepoint. 0=D93, 1=D75, 2=D65, 3=D60, 4=D55, 5=D50
+    float cwp_lm;   // Limit the intensity range affected by the Creative Whitepoint.
+
+    // Render space
+    float rs_sa; // Strength controls how much to desaturate from P3 gamut.
+    float rs_rw; // The Red weight of the Render Space Strength.
+    float rs_bw; // The Blue weight of the Render Space Strength.
+
+    // Purity compress high
+    bool pt_enable; // Compresses purity as intensity increases.
+    float pt_lml;   // Limit the strength of purity compression as intensity decreases, for all hue angles.
+    float pt_lml_r; // Limit the strength of purity compression as intensity decreases, for reds.
+    float pt_lml_g; // Limit the strength of purity compression as intensity decreases, for greens.
+    float pt_lml_b; // Limit the strength of purity compression as intensity decreases, for blues.
+    float pt_lmh;   // Limit the strength of purity compression as intensity increases.
+    float pt_lmh_r; // Limit the strength of red purity compression as intensity increases.
+    float pt_lmh_b; // Limit the strength of blue purity compression as intensity increases.
+    float pt_hdr;   // How much to affect purity compression and hue shift as Peak Luminance increases.
+
+    // Purity softclip
+    bool ptl_enable; // Purity Softclip increases tonality and smoothness in extremely pure input values.
+    float ptl_c;     // Purity Softclip strength for Cyan.
+    float ptl_m;     // Purity Softclip strength for Magenta.
+    float ptl_y;     // Purity Softclip strength for Yellow.
+
+    // Mid purity
+    bool ptm_enable;     // The Mid Purity module adjusts mid-range purity of midtones and highlights.
