+// Core math helpers
+float compress_toe_quadratic(float x, float toe, int inv) {
+    if (toe == 0.0) return x;
+    if (inv == 0) return (x * x) / (x + toe);
+    return (x + sqrt(max(0.0, x * (4.0 * toe + x)))) * 0.5;
+}
+
+float cbrt_safe(float x) {
+    return x < 0.0 ? -pow(-x, 1.0 / 3.0) : pow(x, 1.0 / 3.0);
+}
+
+float compress_toe_cubic(float x, float m, float w, int inv) {
+    if (m == 1.0) return x;
+    float x2 = x * x;
+    if (inv == 0) {
+        return x * (x2 + m * w) / (x2 + w);
+    } else {
+        float p0 = x2 - 3.0 * m * w;
+        float p1 = 2.0 * x2 + 27.0 * w - 9.0 * m * w;
+        float inner = x2 * p1 * p1 - 4.0 * p0 * p0 * p0;
+        float p2 = cbrt_safe(max(0.0, sqrt(max(0.0, inner)) * 0.5 + x * p1 * 0.5));
+        return p0 / (3.0 * max(p2, 1e-5)) + p2 / 3.0 + x / 3.0;
+    }
+}
+
+float compress_hyperbolic_power(float x, float s, float p) {
+    return pow(x / (x + s), p);
+}
+
+float contrast_high(float x, float p, float pv, float pv_lx, int inv) {
+    float x0 = 0.18 * pow(2.0, pv);
+    if (x < x0 || p == 1.0) return x;
+    float o = x0 - x0 / p;
+    float s0 = pow(x0, 1.0 - p) / p;
+    float x1 = x0 * pow(2.0, pv_lx);
+    float k1 = p * s0 * pow(x1, p) / x1;
+    float y1 = s0 * pow(x1, p) + o;
+    if (inv == 1) {
+        return x > y1 ? (x - y1) / k1 + x1 : pow(max(0.0, (x - o) / s0), 1.0 / p);
+    } else {
+        return x > x1 ? k1 * (x - x1) + y1 : s0 * pow(x, p) + o;
+    }
+}
+
+float softplus(float x, float s) {
+    if (x > 10.0 * s || s < 1e-4) return x;
+    return s * log(max(0.0, 1.0 + exp(x / s)));
+}
+
+vec2 opponent(vec3 rgb) {
+    return vec2(rgb.r - rgb.b, rgb.g - (rgb.r + rgb.b) * 0.5);
+}
+
+float hue_offset(float h, float o) {
+    return mod(h - o + OPENDRT_PI, 2.0 * OPENDRT_PI) - OPENDRT_PI;
+}
+
+float gauss_window(float x, float w) {
+    return exp(-x * x / w);
+}
+
+vec3 opendrt(vec3 rgb, OpenDRTParams params) {
+    // Tonescale constraint calculations
+    float ts_x1 = pow(2.0, 6.0 * params.tn_sh + 4.0);
+    float ts_y1 = params.tn_Lp / 100.0;
+    float ts_x0 = 0.18 + params.tn_off;
+    float ts_y0 = (params.tn_Lg / 100.0) * (1.0 + params.tn_gb * log2(ts_y1));
+    float ts_s0 = compress_toe_quadratic(ts_y0, params.tn_toe, 1);
+    float ts_p = params.tn_con / (1.0 + float(params.tn_su) * 0.05);
+    float ts_s10 = ts_x0 * (pow(ts_s0, -1.0 / params.tn_con) - 1.0);
+    float ts_m1 = ts_y1 / pow(ts_x1 / (ts_x1 + ts_s10), params.tn_con);
+    float ts_m2 = compress_toe_quadratic(ts_m1, params.tn_toe, 1);
+    float ts_s = ts_x0 * (pow(ts_s0 / ts_m2, -1.0 / params.tn_con) - 1.0);
+
+    // Linear output scaling (equivalent to standard display mapping)
+    float ts_dsc = 100.0 / params.tn_Lp;
+
+    float pt_cmp_Lf = params.pt_hdr * min(1.0, (params.tn_Lp - 100.0) / 900.0);
+    float s_Lp100 = ts_x0 * (pow((params.tn_Lg / 100.0), -1.0 / params.tn_con) - 1.0);
+    float ts_s1 = ts_s * pt_cmp_Lf + s_Lp100 * (1.0 - pt_cmp_Lf);
+
+    // Rendering space
+    vec3 rs_w = vec3(params.rs_rw, 1.0 - params.rs_rw - params.rs_bw, params.rs_bw);
+    float sat_L = dot(rgb, rs_w);
+    rgb = sat_L * params.rs_sa + rgb * (1.0 - params.rs_sa);
+
+    // Offset
+    rgb += params.tn_off;
+
+    // Tonescale norm & ratios
+    float tsn = length(rgb) / 1.73205080757;
+    rgb /= tsn;
+
+    // Opponent & achromatic distance
+    vec2 opp = opponent(rgb);
+    float ach_d = length(opp) * 0.5;
+    ach_d = 1.25 * compress_toe_quadratic(ach_d, 0.25, 0);
+
+    // Hue angle
+    float hue = mod(atan(opp.x, opp.y) + 3.14159265359 + 1.10714931, 2.0 * 3.14159265359);
+
+    // Hue windows
+    vec3 ha_rgb = vec3(
+        gauss_window(hue_offset(hue, 0.1), 0.66),
+                       gauss_window(hue_offset(hue, 4.3), 0.66),
+                       gauss_window(hue_offset(hue, 2.3), 0.66)
+    );
+    vec3 ha_rgb_hs = vec3(
+        gauss_window(hue_offset(hue, -0.4), 0.66),
+                          ha_rgb.y,
+                          gauss_window(hue_offset(hue, 2.5), 0.66)
+    );
+    vec3 ha_cmy = vec3(
+        gauss_window(hue_offset(hue, 3.3), 0.5),
+                       gauss_window(hue_offset(hue, 1.3), 0.5),
+                       gauss_window(hue_offset(hue, -1.15), 0.5)
+    );
+
+    // Brilliance
+    if (params.brl_enable == 1) {
+        float brl_tsf = pow(tsn / (tsn + 1.0), 1.0 - params.brl_rng);
+        float brl_exf = (params.brl + params.brl_r * ha_rgb.x + params.brl_g * ha_rgb.y + params.brl_b * ha_rgb.z) * pow(ach_d, 1.0 / params.brl_st);
+        float brl_ex = pow(2.0, brl_exf * (brl_exf < 0.0 ? brl_tsf : 1.0 - brl_tsf));
+        tsn *= brl_ex;
+    }
+
+    // Contrast low
+    if (params.tn_lcon_enable == 1) {
+        float lcon_m = pow(2.0, -params.tn_lcon);
+        float lcon_w = params.tn_lcon_w / 4.0;
+        lcon_w *= lcon_w;
+        float lcon_cnst_sc = compress_toe_cubic(ts_x0, lcon_m, lcon_w, 1) / ts_x0;
+        tsn *= lcon_cnst_sc;
+        tsn = compress_toe_cubic(tsn, lcon_m, lcon_w, 0);
+    }
+
+    // Contrast high
+    if (params.tn_hcon_enable == 1) {
+        float hcon_p = pow(2.0, params.tn_hcon);
+        tsn = contrast_high(tsn, hcon_p, params.tn_hcon_pv, params.tn_hcon_st, 0);
+    }
+
+    // Hyperbolic compression
+    float tsn_pt = compress_hyperbolic_power(tsn, ts_s1, ts_p);
+    float tsn_const = compress_hyperbolic_power(tsn, s_Lp100, ts_p);
+    tsn = compress_hyperbolic_power(tsn, ts_s, ts_p);
+
+    // Hue contrast R
+    if (params.hc_enable == 1) {
+        float hc_ts = 1.0 - tsn_const;
+        float hc_c = hc_ts * (1.0 - ach_d) + ach_d * (1.0 - hc_ts);
+        hc_c *= ach_d * ha_rgb.x;
+        hc_ts = pow(hc_ts, 1.0 / params.hc_r_rng);
+        float hc_f = params.hc_r * (hc_c - 2.0 * hc_c * hc_ts) + 1.0;
+        rgb.g *= hc_f;
+        rgb.b *= hc_f;
+    }
+
+    // Hue shift RGB
+    if (params.hs_rgb_enable == 1) {
+        vec3 hs_rgb = vec3(
+            ha_rgb_hs.x * ach_d * pow(tsn_pt, 1.0 / params.hs_r_rng),
+                           ha_rgb_hs.y * ach_d * pow(tsn_pt, 1.0 / params.hs_g_rng),
+                           ha_rgb_hs.z * ach_d * pow(tsn_pt, 1.0 / params.hs_b_rng)
+        );
+        vec3 hsf = vec3(hs_rgb.x * params.hs_r, hs_rgb.y * -params.hs_g, hs_rgb.z * -params.hs_b);
+        hsf = vec3(hsf.z - hsf.y, hsf.x - hsf.z, hsf.y - hsf.x);
+        rgb += hsf;
+    }
+
+    // Hue shift CMY
+    if (params.hs_cmy_enable == 1) {
+        float tsn_pt_compl = 1.0 - tsn_pt;
+        vec3 hs_cmy = vec3(
+            ha_cmy.x * ach_d * pow(tsn_pt_compl, 1.0 / params.hs_c_rng),
+                           ha_cmy.y * ach_d * pow(tsn_pt_compl, 1.0 / params.hs_m_rng),
+                           ha_cmy.z * ach_d * pow(tsn_pt_compl, 1.0 / params.hs_y_rng)
+        );
+        vec3 hsf = vec3(hs_cmy.x * -params.hs_c, hs_cmy.y * params.hs_m, hs_cmy.z * params.hs_y);
+        hsf = vec3(hsf.z - hsf.y, hsf.x - hsf.z, hsf.y - hsf.x);
+        rgb += hsf;
+    }
+
+    // Purity compression
+    float pt_lml_p = 1.0 + 4.0 * (1.0 - tsn_pt) * (params.pt_lml + params.pt_lml_r * ha_rgb_hs.x + params.pt_lml_g * ha_rgb_hs.y + params.pt_lml_b * ha_rgb_hs.z);
+    float ptf = 1.0 - pow(tsn_pt, pt_lml_p);
+    float pt_lmh_p = (1.0 - ach_d * (params.pt_lmh_r * ha_rgb_hs.x + params.pt_lmh_b * ha_rgb_hs.z)) * (1.0 - params.pt_lmh * ach_d);
+    ptf = pow(ptf, pt_lmh_p);
+
+    // Mid-range purity
+    if (params.ptm_enable == 1) {
+        float ptm_low_f = (params.ptm_low_st == 0.0 || params.ptm_low_rng == 0.0) ? 1.0 :
+        1.0 + params.ptm_low * exp(-2.0 * ach_d * ach_d / params.ptm_low_st) * pow(1.0 - tsn_const, 1.0 / params.ptm_low_rng);
+        float ptm_high_f = (params.ptm_high_st == 0.0 || params.ptm_high_rng == 0.0) ? 1.0 :
+        1.0 + params.ptm_high * exp(-2.0 * ach_d * ach_d / params.ptm_high_st) * pow(tsn_pt, 1.0 / (4.0 * params.ptm_high_rng));
+        ptf *= ptm_low_f * ptm_high_f;
+    }
+
+    // Lerp to peak achromatic
+    rgb = rgb * ptf + (1.0 - ptf);
+
+    // Inverse rendering space
+    sat_L = dot(rgb, rs_w);
+    rgb = (sat_L * params.rs_sa - rgb) / (params.rs_sa - 1.0);
+
+    // Post brilliance
+    if (params.brlp_enable == 1) {
+        vec2 brlp_opp = opponent(rgb);
+        float brlp_ach_d = length(brlp_opp) * 0.25;
+        brlp_ach_d = 1.1 * (brlp_ach_d * brlp_ach_d / (brlp_ach_d + 0.1));
+        vec3 brlp_ha_rgb = ach_d * ha_rgb;
+        float brlp_m = params.brlp + params.brlp_r * brlp_ha_rgb.x + params.brlp_g * brlp_ha_rgb.y + params.brlp_b * brlp_ha_rgb.z;
+        float brlp_ex = pow(2.0, brlp_m * brlp_ach_d * tsn);
+        rgb *= brlp_ex;
+    }
+
+    // Purity compress
+    if (params.ptl_enable == 1) {
+        rgb = vec3(softplus(rgb.r, params.ptl_c), softplus(rgb.g, params.ptl_m), softplus(rgb.b, params.ptl_y));
+    }
+
+    // Final tonescale adjustments
+    tsn *= ts_m2;
+    tsn = compress_toe_quadratic(tsn, params.tn_toe, 0);
+    tsn *= ts_dsc;
+
+    // Recombine
+    rgb *= tsn;
+
+    // Clamp to valid linear range
+    rgb = clamp(rgb, 0.0, 1.0);
+
+    return rgb;
+}
